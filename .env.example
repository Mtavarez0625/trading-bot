# ==============================================================================
# Trading Bot — Environment Variables Reference
# ==============================================================================
# Copy this file to .env in the relevant directory and fill in your values.
# NEVER commit .env files with real credentials.
#
#   bot/        → copy to bot/.env
#   apps/api/   → copy to apps/api/.env
# ==============================================================================


# ------------------------------------------------------------------------------
# Alpaca API Credentials (required)
# Get these from https://app.alpaca.markets/paper-trading/overview
# ------------------------------------------------------------------------------
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper trading mode — set to false ONLY when you are ready for live trading
ALPACA_PAPER=true

# Alpaca base URLs (used by the API layer; bot/ derives these from ALPACA_PAPER)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets


# ------------------------------------------------------------------------------
# Dry Run Mode
# When true: signals are evaluated and logged, but NO orders are submitted.
# Use this to verify strategy behavior before enabling real order flow.
# ------------------------------------------------------------------------------
DRY_RUN=true


# ------------------------------------------------------------------------------
# Watchlist — Symbol Groups (bot/ module)
# ------------------------------------------------------------------------------

# Equities watchlist (comma-separated, no spaces)
EQUITIES=AAPL,MSFT,GOOGL

# Index ETFs watchlist
INDEX_ETFS=SPY,QQQ

# Commodities watchlist (optional; GLD, IAU, etc.)
COMMODITIES=

# Legacy flat watchlist — used if EQUITIES/INDEX_ETFS are not set (apps/api/)
WATCHLIST=AAPL,MSFT,GOOGL,SPY,QQQ


# ------------------------------------------------------------------------------
# Risk Parameters
# ------------------------------------------------------------------------------

# Fraction of account equity to risk per trade (e.g. 0.01 = 1%)
RISK_PER_TRADE=0.01
RISK_PER_TRADE_PCT=0.01

# Stop-loss distance from entry price as a fraction (e.g. 0.02 = 2%)
STOP_LOSS_PCT=0.02

# Take-profit distance from entry price as a fraction (e.g. 0.04 = 4%)
TAKE_PROFIT_PCT=0.04

# Trailing stop distance (0 = disabled, use fixed stop)
TRAILING_STOP_PCT=0.0

# Maximum fraction of equity allocated to a single position
MAX_ALLOCATION_PCT=0.10

# Daily loss stop: halt new entries if equity drops this fraction from session start
DAILY_LOSS_STOP=0.03
DAILY_LOSS_LIMIT_PCT=0.03


# ------------------------------------------------------------------------------
# Position & Trade Limits
# ------------------------------------------------------------------------------

# Maximum simultaneous open positions
MAX_POSITIONS=3
MAX_OPEN_POSITIONS=3

# Maximum trades per symbol per day
MAX_TRADES_PER_SYMBOL=2

# Cooldown between trades on the same symbol (minutes)
TRADE_COOLDOWN_MINUTES=15


# ------------------------------------------------------------------------------
# Signal Parameters (apps/api/ layer)
# ------------------------------------------------------------------------------

# RSI settings
RSI_PERIOD=14
RSI_OVERBOUGHT=75

# Minimum trend strength threshold
MIN_TREND_STRENGTH=0.01

# Volume confirmation ratio (current volume / rolling average)
MIN_VOLUME_RATIO=1.0

# Breakout lookback period (bars)
BREAKOUT_LOOKBACK=20

# Intraday and daily timeframe strings
INTRADAY_TIMEFRAME=15Min
DAILY_TIMEFRAME=1Day

# Early trend entry — allows entry before full EMA alignment
ALLOW_EARLY_TREND_ENTRY=false
EARLY_TREND_MAX_SMA_GAP_PCT=0.005

# Additional confirmation filters
REQUIRE_BREAKOUT_FOR_BUY=false
REQUIRE_INTRADAY_CONFIRMATION=false
REQUIRE_SPY_BULLISH=false
